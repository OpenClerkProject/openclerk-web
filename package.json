{
  "name": "openclerk-web",
  "version": "0.1.0",
  "description": "A standalone, client-side-only Bluebook citation checker — paste a citation, get formatting issues back. No server, no install, built on openclerk-core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenClerkProject/openclerk-web.git"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "watch": "node scripts/build.js --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "openclerk-core": "v0.4.2",
    "pdfjs-dist": "^4.6.82",
    "scribe.js-ocr": "^0.14.0-0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tesseract.js-data/eng": "^1.0.0",
    "@types/jest": "^29.0.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.23.0",
    "fast-check": "^3.23.2",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.2"
  }
}
